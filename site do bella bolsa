  }
  .toast-msg.show { opacity: 1; }

  textarea:focus, .option-btn:focus { outline: none; box-shadow: 0 0 0 2px rgba(139,105,20,0.4); }

  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-thumb { background: #C4A96A; border-radius: 4px; }
</style>
