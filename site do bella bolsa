  <script>
  // State
  const surveyAnswers = {};
  let currentRecordCount = 0;

  const defaultConfig = {
    store_name: 'Bella Bolsa',
    store_tagline: 'Elegância em cada detalhe',
    thank_you_message: 'Obrigado pelo seu feedback!',
    background_color: '#FAF3E0',
    surface_color: '#FFFFFF',
    text_color: '#2D2015',
    primary_action_color: '#2D2015',
    accent_color: '#C4A96A'
  };

  function goTo(screen) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    const el = document.getElementById('screen-' + screen);
    if (el) { el.classList.add('active'); }
    lucide.createIcons();
  }

  function selectOption(btn, key) {
    const parent = btn.closest('[data-q]') || btn.parentElement;
    parent.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    surveyAnswers[key] = btn.textContent.trim();
  }

  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2500);
  }

  async function submitSurvey() {
    const required = ['satisfaction','service','quality','price','buy_again','variety','design'];
    const missing = required.filter(k => !surveyAnswers[k]);
    if (missing.length > 0) { showToast('Por favor, responda todas as perguntas'); return; }
    if (currentRecordCount >= 999) { showToast('Limite de registros atingido'); return; }

    const btn = document.getElementById('btn-submit-survey');
    btn.disabled = true; btn.textContent = 'Enviando...';

    const result = await window.dataSdk.create({
      type: 'survey',
      satisfaction: surveyAnswers.satisfaction || '',
      service: surveyAnswers.service || '',
      quality: surveyAnswers.quality || '',
      price: surveyAnswers.price || '',
      buy_again: surveyAnswers.buy_again || '',
      variety: surveyAnswers.variety || '',
      design: surveyAnswers.design || '',
      message: '',
      created_at: new Date().toISOString()
    });

    btn.disabled = false; btn.textContent = 'Enviar Pesquisa';
    if (result.isOk) {
      // Reset selections
      document.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
      Object.keys(surveyAnswers).forEach(k => delete surveyAnswers[k]);
      goTo('thanks');
    } else { showToast('Erro ao enviar. Tente novamente.'); }
  }

  async function submitFeedback(type) {
    const textarea = document.getElementById(type + '-text');
    const msg = textarea.value.trim();
    if (!msg) { showToast('Por favor, escreva sua mensagem'); return; }
    if (currentRecordCount >= 999) { showToast('Limite de registros atingido'); return; }

    const btn = document.getElementById('btn-' + type);
    btn.disabled = true; btn.textContent = 'Enviando...';

    const result = await window.dataSdk.create({
      type: type,
      satisfaction: '', service: '', quality: '', price: '',
      buy_again: '', variety: '', design: '',
      message: msg,
      created_at: new Date().toISOString()
    });

    btn.disabled = false;
    const labels = { complaint: 'Enviar Reclamação', suggestion: 'Enviar Sugestão', compliment: 'Enviar Elogio' };
    btn.textContent = labels[type];
    if (result.isOk) { textarea.value = ''; goTo('thanks'); }
    else { showToast('Erro ao enviar. Tente novamente.'); }
  }

  // Data SDK with auto-sync
  let allFeedback = [];
  const dataHandler = {
    onDataChanged(data) {
      allFeedback = data;
      currentRecordCount = data.length;
      renderFeedbackTable(data);
    }
  };

  function renderFeedbackTable(data) {
    const tbody = document.getElementById('feedback-table-body');
    if (!data || data.length === 0) {
      tbody.innerHTML = '<tr style="border-bottom:1px solid #E8DCC8;"><td colspan="3" style="padding:20px; text-align:center; color:#9B8B7B;">Nenhum feedback ainda</td></tr>';
      return;
    }

    const existingRows = new Map(
      [...tbody.querySelectorAll('tr')].map(row => [row.dataset.id, row])
    );

    const typeLabels = { survey: '📊 Pesquisa', complaint: '⚠️ Reclamação', suggestion: '💡 Sugestão', compliment: '❤️ Elogio' };

    data.forEach((record) => {
      const typeLabel = typeLabels[record.type] || record.type;
      
      let msg = record.message || '';
      if (record.type === 'survey') {
        const parts = [];
        if (record.satisfaction) parts.push(`Satisfação: ${record.satisfaction}`);
        if (record.service) parts.push(`Atend.: ${record.service}`);
        msg = parts.join(' | ') || 'Pesquisa completa';
      }
      msg = msg.substring(0, 50) + (msg.length > 50 ? '...' : '');

      const dateObj = record.created_at ? new Date(record.created_at) : new Date();
      const dateStr = dateObj.toLocaleDateString('pt-BR') + ' ' + dateObj.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });

      if (existingRows.has(record.__backendId)) {
        const row = existingRows.get(record.__backendId);
        row.innerHTML = `<td style="padding:10px; border-right:1px solid #E8DCC8; color:#2D2015; font-weight:500;">${typeLabel}</td><td style="padding:10px; border-right:1px solid #E8DCC8; color:#6B5B4B;">${msg}</td><td style="padding:10px; color:#9B8B7B; font-size:12px;">${dateStr}</td>`;
        existingRows.delete(record.__backendId);
      } else {
        const row = document.createElement('tr');
        row.dataset.id = record.__backendId;
        row.style.cssText = 'border-bottom:1px solid #E8DCC8; animation: fadeIn 0.3s ease;';
        row.innerHTML = `<td style="padding:10px; border-right:1px solid #E8DCC8; color:#2D2015; font-weight:500;">${typeLabel}</td><td style="padding:10px; border-right:1px solid #E8DCC8; color:#6B5B4B;">${msg}</td><td style="padding:10px; color:#9B8B7B; font-size:12px;">${dateStr}</td>`;
        tbody.appendChild(row);
      }
    });

    existingRows.forEach(row => row.remove());
  }

  // Element SDK
  function applyConfig(config) {
    const c = { ...defaultConfig, ...config };
    const title = document.getElementById('home-title');
    const tagline = document.getElementById('home-tagline');
    const thanksMsg = document.getElementById('thanks-msg');
    if (title) title.textContent = c.store_name;
    if (tagline) tagline.textContent = c.store_tagline;
    if (thanksMsg) thanksMsg.textContent = c.thank_you_message;

    // Colors
    const app = document.getElementById('app');
    app.style.background = `linear-gradient(180deg, ${c.background_color} 0%, ${c.background_color}dd 100%)`;

    document.querySelectorAll('[style*="background:white"]').forEach(el => {
      el.style.background = c.surface_color;
    });

    document.querySelectorAll('h1, h2, .text-sm.font-semibold, textarea').forEach(el => {
      if (el.style.color === 'rgb(45, 32, 21)' || el.style.color === '#2D2015' || !el.style.color) {
        el.style.color = c.text_color;
      }
    });
  }

  window.elementSdk.init({
    defaultConfig,
    onConfigChange: async (config) => { applyConfig(config); },
    mapToCapabilities: (config) => {
      const c = { ...defaultConfig, ...config };
      function mut(key) {
        return {
          get: () => c[key] || defaultConfig[key],
          set: (v) => { c[key] = v; window.elementSdk.setConfig({ [key]: v }); }
        };
      }
      return {
        recolorables: [mut('background_color'), mut('surface_color'), mut('text_color'), mut('primary_action_color'), mut('accent_color')],
        borderables: [],
        fontEditable: {
          get: () => c.font_family || 'Montserrat',
          set: (v) => { c.font_family = v; window.elementSdk.setConfig({ font_family: v }); }
        },
        fontSizeable: undefined
      };
    },
    mapToEditPanelValues: (config) => {
      const c = { ...defaultConfig, ...config };
      return new Map([
        ['store_name', c.store_name],
        ['store_tagline', c.store_tagline],
        ['thank_you_message', c.thank_you_message]
      ]);
    }
  });

  (async () => {
    const r = await window.dataSdk.init(dataHandler);
    if (!r.isOk) console.error('Data SDK init failed');
  })();

  lucide.createIcons();
</script>
